{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://observability.platform.io/schemas/onboarding/v1.json",
  "title": "ObservabilityOnboarding",
  "description": "Onboarding configuration for the Observability Easy Button framework",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "observability.platform.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "ObservabilityOnboarding"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "namespace": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["application"],
      "properties": {
        "application": {
          "type": "object",
          "required": ["name", "namespace", "service", "team", "environment"],
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" },
            "service": { "type": "string" },
            "team": { "type": "string" },
            "environment": {
              "type": "string",
              "enum": ["dev", "staging", "prod"]
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "path": { "type": "string", "default": "/metrics" },
            "port": { "type": "integer" }
          }
        },
        "logs": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "format": {
              "type": "string",
              "enum": ["json", "logfmt"]
            }
          }
        },
        "dashboards": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "template_set": {
              "type": "string",
              "enum": ["service-overview", "golden-signals"]
            }
          }
        },
        "alerts": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "notification_channels": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
